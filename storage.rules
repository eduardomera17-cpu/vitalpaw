rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {

    // Solo usuarios autenticados pueden leer archivos
    match /pet_photos/{allPaths=**} {
      allow read: if true; // Fotos de mascotas son públicas
      allow write: if request.auth != null
        && request.resource.size < 5 * 1024 * 1024 // Máx 5MB
        && request.resource.contentType.matches('image/.*');
    }

    match /profile_photos/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if request.auth != null
        && request.auth.uid == userId
        && request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /medical_files/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null
        && request.auth.token.role in ['admin', 'staff']
        && request.resource.size < 10 * 1024 * 1024; // Máx 10MB
    }

    // Denegar todo lo demás
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
